# Copy to .env.local. All values have sane defaults for a local demo.

# Monad testnet
NEXT_PUBLIC_MONAD_CHAIN_ID=10143
NEXT_PUBLIC_MONAD_RPC_URL=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_EXPLORER_URL=https://testnet.monadexplorer.com

# WalletConnect project id (https://cloud.walletconnect.com). Injected wallets
# (MetaMask) work without a real id; set one to enable the WalletConnect modal.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Backend (FastAPI)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Deployed contracts (from contracts/deployments/monadTestnet.json). Optional —
# only used for the audit page's on-chain verify; the app works without them.
NEXT_PUBLIC_PROVIDER_REGISTRY_ADDRESS=
NEXT_PUBLIC_EXECUTION_ATTESTATION_ADDRESS=
