# Deployer private key (0x-prefixed, 64 hex chars). Fund this address with testnet MON
# from the Monad faucet before deploying.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Monad testnet RPC (default shown). Override if you use a private endpoint.
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Optional: explorer API key for `hardhat verify`. Verification is not required for the demo.
EXPLORER_API_KEY=empty
