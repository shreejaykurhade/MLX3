# ─────────────────────────────────────────────────────────────────────────────
# MLX3 — full-stack environment reference. Each sub-project also has its own
# .env.example; this file documents the whole stack in one place.
# ─────────────────────────────────────────────────────────────────────────────

# --- Contracts (contracts/.env) ---------------------------------------------
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# --- Backend (backend/.env, Step 2) -----------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...
# The deployer key the backend uses to submit attestations on Monad:
AGENT_PRIVATE_KEY=0xYOUR_AGENT_PRIVATE_KEY
PROVIDER_REGISTRY_ADDRESS=0x...        # from contracts/deployments/monadTestnet.json
EXECUTION_ATTESTATION_ADDRESS=0x...    # from contracts/deployments/monadTestnet.json

# --- Frontend (frontend/.env.local, Step 3) ---------------------------------
NEXT_PUBLIC_MONAD_CHAIN_ID=10143
NEXT_PUBLIC_MONAD_RPC_URL=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=...
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_PROVIDER_REGISTRY_ADDRESS=0x...
NEXT_PUBLIC_EXECUTION_ATTESTATION_ADDRESS=0x...
