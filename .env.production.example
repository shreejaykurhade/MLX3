# Public DNS names. Create A/AAAA records for both names pointing to this server.
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
DEPLOY_DOMAIN=deploy.example.com
ACME_EMAIL=admin@example.com
POSTGRES_PASSWORD=replace-with-a-long-random-password
JWT_SECRET=replace-with-a-random-64-character-hex-string
SIWE_DOMAIN=app.example.com

# Agent. Leave ANTHROPIC_API_KEY empty to keep the scripted mock agent.
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-opus-4-8
USE_MOCK_AGENT=false

# Resource limits for each deployed public repository.
DEPLOY_MEMORY_LIMIT=512m
DEPLOY_CPUS=1
DEPLOY_PIDS_LIMIT=256
DEPLOY_DEFAULT_PORT=3000

# Reserved for future private-repository support. Public repositories do not use these.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXT_PUBLIC_GITHUB_CLIENT_ID=

# Monad testnet. This repository does not implement the Sepolia/EAS contracts from
# the larger environment template.
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_CHAIN_ID=10143
EXPLORER_URL=https://testnet.monadexplorer.com
AGENT_WALLET_PRIVATE_KEY=
PROVIDER_REGISTRY_ADDRESS=
EXECUTION_ATTESTATION_ADDRESS=

# Alternative persistence for environments not using the bundled Postgres service.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Frontend values are embedded at image build time.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_MONAD_CHAIN_ID=10143
NEXT_PUBLIC_MONAD_RPC_URL=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_EXPLORER_URL=https://testnet.monadexplorer.com
NEXT_PUBLIC_PROVIDER_REGISTRY_ADDRESS=
NEXT_PUBLIC_EXECUTION_ATTESTATION_ADDRESS=
