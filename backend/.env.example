# ─── Agent ───────────────────────────────────────────────────────────────────
# Without an API key the backend uses a scripted mock agent (the demo still works).
ANTHROPIC_API_KEY=sk-ant-...
# Default is the most capable model. For a faster/cheaper demo loop use claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-opus-4-8
# Force the scripted agent even if a key is present:
USE_MOCK_AGENT=false

# ─── Monad testnet ───────────────────────────────────────────────────────────
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_CHAIN_ID=10143
EXPLORER_URL=https://testnet.monadexplorer.com
# Wallet the backend uses to submit attestations. Without it, attestation is simulated.
AGENT_PRIVATE_KEY=0xYOUR_AGENT_PRIVATE_KEY
# Contract addresses. If omitted, they're auto-loaded from
# ../contracts/deployments/monadTestnet.json (written by `npm run deploy:monad`).
PROVIDER_REGISTRY_ADDRESS=
EXECUTION_ATTESTATION_ADDRESS=

# ─── Supabase (optional) ─────────────────────────────────────────────────────
# Without these the backend uses an in-memory store (fine for a single-run demo).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── HTTP ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
